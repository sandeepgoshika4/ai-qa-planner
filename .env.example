HEADLESS=false
SLOW_MO=500
STEP_DELAY_MS=400
KEEP_BROWSER_OPEN=false
MAX_AGENT_ACTIONS_PER_STEP=8

# Enable or disable page context change logging from the watcher (true/false)
WATCHER_LOGGING=true
# How long (ms) the page must be quiet before the watcher emits the final context change
WATCHER_SETTLE_MS=800

# Switch between "openai" and "copilot"
# copilot requires the vscode-copilot-proxy extension running (press F5 in that folder)
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# VS Code Copilot proxy (used when LLM_PROVIDER=copilot)
# Model name must match what vscode.lm reports, e.g. claude-sonnet-4-6, claude-opus-4-6
LLM_PROXY_URL=http://localhost:3100/v1

XRAY_CLIENT_ID=
XRAY_CLIENT_SECRET=
XRAY_BASE_URL=https://xray.cloud.getxray.app/api/v2
XRAY_GRAPHQL_URL=https://xray.cloud.getxray.app/api/v2/graphql

JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
