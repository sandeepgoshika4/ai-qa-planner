HEADLESS=false
SLOW_MO=500
STEP_DELAY_MS=400
KEEP_BROWSER_OPEN=false
# Maximum Playwright actions the LLM can plan for a single test step.
# Simple steps (click + assert) need ~3. Complex form steps can need 20-30+.
MAX_AGENT_ACTIONS_PER_STEP=30

# Maximum number of page elements sent to LLM per planning call (default: 60)
# Only visible, enabled, interactive elements are counted — hidden/decorative are already excluded.
MAX_PLANNER_ELEMENTS=60

# Enable or disable page context change logging from the watcher (true/false)
WATCHER_LOGGING=true
# How long (ms) the page must be quiet before the watcher emits the final context change
WATCHER_SETTLE_MS=800

# Switch between "openai" and "copilot"
# copilot requires the vscode-copilot-proxy extension running (press F5 in that folder)
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Visual element fallback — when a selector fails on the final heal attempt,
# takes a screenshot and asks a vision model to locate the element visually.
# Requires a vision-capable model (gpt-4o, gpt-4-turbo, claude-3-5-sonnet, etc.)
VISUAL_LOCATOR_ENABLED=false
VISION_MODEL=gpt-4o

# How many times to attempt healing a failed action before giving up (default: 2)
HEAL_MAX_ATTEMPTS=2

# VS Code Copilot proxy (used when LLM_PROVIDER=copilot)
# Model name must match what vscode.lm reports, e.g. claude-sonnet-4-6, claude-opus-4-6
LLM_PROXY_URL=http://localhost:3100/v1

XRAY_CLIENT_ID=
XRAY_CLIENT_SECRET=
XRAY_BASE_URL=https://xray.cloud.getxray.app/api/v2
XRAY_GRAPHQL_URL=https://xray.cloud.getxray.app/api/v2/graphql

JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
